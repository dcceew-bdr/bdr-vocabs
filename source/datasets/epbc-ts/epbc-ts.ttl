PREFIX afd: <http://biodiversity.org.au/afd.taxon/>
PREFIX apni: <https://id.biodiversity.org.au/name/apni/>
PREFIX cats: <https://linked.data.gov.au/def/epbc-ts-cats/>
PREFIX d: <https://linked.data.gov.au/dataset/epbc-ts>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX status: <https://def.isotc211.org/RE/ItemStatus/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

d:
    a schema:Dataset ;
    schema:citation "https://www.legislation.gov.au/F2005B02653/latest/text"^^xsd:anyURI ;
    schema:creator <https://linked.data.gov.au/org/dcceew> ;
    schema:dateCreated "2026-04-20"^^xsd:date ;
    schema:dateModified "2026-06-17"^^xsd:date ;
    schema:description """Threatened species as published by a Declaration under s178, s181, and s183 of the Environment Protection and Biodiversity Conservation Act 1999.

The Dataset is subdivided into 6 Containers - one for each category of threatened species - whose IRIs are those of Concepts in the "EPBC Threatened Species Categories" vocabulary (https://linked.data.gov.au/def/epbc-ts-cats).

Plant names are identified using APNI name IRIs where available. Animal taxa are identified using Australian Faunal Directory taxon concept IRIs, generated by reconciling EPBC names against AFD and adding high-confidence one-to-one matches.""" ;
    schema:hasPart
        cats:conservation-dependent ,
        cats:critically-endangered ,
        cats:endangered ,
        cats:extinct ,
        cats:extinct-in-the-wild ,
        cats:vulnerable ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "EPBC Threatened Species" ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    schema:status status:stable ;
    schema:version "C220" ;
.

